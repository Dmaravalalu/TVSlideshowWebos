# Slideshow server environment overrides. All optional; config.json supplies defaults.

# HTTP port the server binds to (0.0.0.0:PORT). Overrides config.json.
PORT=8080

# Absolute path to the media root. Overrides config.json. Examples:
#   Windows:  E:\Photos      or   \\server\share\Photos
#   Linux:    /mnt/photos
# MEDIA_ROOT=E:\Photos

# LRU image cache budget in bytes. Default 536870912 (512 MB).
# CACHE_BYTES=536870912

# Per-image display seconds. Default 5.
# IMG_SEC=5

# Selection mode: sequential | random. Default sequential.
# MODE=sequential

# If set, enables HTTP basic auth on all routes. Format: "user:password".
# BASIC_AUTH=admin:changeme

# If set to "1", reject UNC paths (\\server\share\...) as media root.
# DISABLE_UNC=0
